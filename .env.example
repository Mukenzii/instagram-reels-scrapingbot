# Telegram bot token from @BotFather
BOT_TOKEN=

# Apify API token from https://console.apify.com/account/integrations
APIFY_TOKEN=

# How many reels to fetch when a username/profile URL is sent (ignored for direct reel URLs)
RESULTS_LIMIT=5

# --- Notion integration (optional) ---
# Leave NOTION_TOKEN empty to disable the Notion poller.
# Internal integration token from https://www.notion.so/my-integrations
NOTION_TOKEN=
# Database ID (the 32-char id in the database URL)
NOTION_DATABASE_ID=
# How often (seconds) to poll the database for new links
NOTION_POLL_SECONDS=120
